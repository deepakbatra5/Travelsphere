{
  "name": "travelsphere",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "postinstall": "prisma generate",
    "dev:raw": "node --no-deprecation scripts/dev-wrapper.js",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "setup-hosts": "node scripts/setup-local-hosts.js",
    "build": "next build",
    "vercel-build": "npm run prisma:generate && (npm run db:migrate:deploy || npm run db:push) && npm run seed && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@openrouter/sdk": "^0.12.35",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "next-cloudinary": "^6.17.5",
    "nodemailer": "^7.0.13",
    "openai": "^6.36.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "slugify": "^1.6.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
