# Production Environment Variables — TravelSphere
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_DB_PASS@localhost:5432/travel_db"
DIRECT_URL="postgresql://postgres:YOUR_DB_PASS@localhost:5432/travel_db"

# ─── NextAuth ──────────────────────────────────────────────
# Production: NEXTAUTH_URL must be your primary customer domain
NEXTAUTH_URL="https://travelsphere.sbs"
# Internal URL used by Next.js server-to-server calls
NEXTAUTH_URL_INTERNAL="http://127.0.0.1:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# ─── Portal Domains ────────────────────────────────────────
ROOT_DOMAIN="travelsphere.sbs"
NEXT_PUBLIC_ROOT_DOMAIN="travelsphere.sbs"

# ─── Seed Admin ────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@travelsphere.com"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"

# ─── Razorpay ──────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_replace_me"
RAZORPAY_KEY_SECRET="replace-me"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_replace_me"

# ─── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="travel_sphere_packages"

# ─── Email (Gmail SMTP) ────────────────────────────────────
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your@gmail.com"
EMAIL_PASS="your-app-password"

# ─── OTP Settings ──────────────────────────────────────────
EMAIL_OTP_EXPIRES_MINUTES=5
EMAIL_OTP_MAX_ATTEMPTS=3
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_RESEND_WINDOW_MINUTES=15
EMAIL_OTP_RESEND_LIMIT=5

# ─── AI (OpenAI / Groq) ────────────────────────────────────
OPENAI_API_KEY="sk-proj-replace-me"
OPENAI_ORG_ID=""
OPENAI_PROJECT_ID=""
GROQ_API_KEY="gsk_replace-me"
GROQ_MODEL="llama-3.1-8b-instant"
