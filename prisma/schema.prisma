generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      Role     @default(USER)
  isEmailVerified Boolean @default(true)
  emailVerifiedAt DateTime?
  emailOtpHash String?
  emailOtpExpiresAt DateTime?
  emailOtpAttempts Int @default(0)
  emailOtpSentAt DateTime?
  emailOtpResendCount Int @default(0)
  passwordResetOtpHash String?
  passwordResetOtpExpiresAt DateTime?
  passwordResetOtpAttempts Int @default(0)
  passwordResetOtpSentAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  reviews   Review[]
  enquiries Enquiry[]
  agent     Agent?
}

enum Role {
  USER
  ADMIN
}

model Package {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  destination String
  description String
  price       Float
  duration    Int      // number of days
  category    Category
  images      String[] // array of image URLs
  itinerary   Json     // day-wise itinerary
  inclusions  String[]
  exclusions  String[]
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]
  tripDates   PackageTripDate[]
  reviews     Review[]
  enquiries   Enquiry[]
  agentPreferences AgentTourPreference[]
}

model PackageTripDate {
  id             String   @id @default(cuid())
  packageId      String
  startDate      DateTime
  totalSeats     Int
  availableSeats Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  package  Package   @relation(fields: [packageId], references: [id])
  bookings Booking[]

  @@unique([packageId, startDate])
  @@index([startDate])
}

enum Category {
  FAMILY
  HONEYMOON
  GROUP
  SOLO
  PILGRIMAGE
  ADVENTURE
  CORPORATE
  COUPLE
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  packageId   String
  tripDateId  String?
  travelDate  DateTime
  travellers  Int
  totalAmount Float
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id])
  package     Package       @relation(fields: [packageId], references: [id])
  tripDate    PackageTripDate? @relation(fields: [tripDateId], references: [id])
  payment     Payment?
  travellersInfo Json?      // traveller names, ages etc
  agentAssignment BookingAgent?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Payment {
  id               String        @id @default(cuid())
  bookingId        String        @unique
  razorpayOrderId  String
  razorpayPaymentId String?
  amount           Float
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())

  booking          Booking       @relation(fields: [bookingId], references: [id])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Enquiry {
  id             String   @id @default(cuid())
  name           String
  phone          String
  email          String?
  message        String
  packageId      String?
  userId         String?
  createdAt      DateTime @default(now())

  package   Package? @relation(fields: [packageId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  packageId String
  rating    Int      // 1-5
  comment   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  package   Package  @relation(fields: [packageId], references: [id])
}

model Agent {
  id         String      @id @default(cuid())
  userId     String      @unique
  phone      String
  city       String
  state      String
  experience Int
  languages  String[]
  bio        String?
  status     AgentStatus @default(PENDING)
  rating     Float       @default(0)
  totalTours Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  companyName String?
  aadharCard  String?
  panCard     String?
  pinCode     String?
  gstNumber   String?

  user             User                  @relation(fields: [userId], references: [id])
  preferredTours   AgentTourPreference[]
  assignedBookings BookingAgent[]
}

enum AgentStatus {
  PENDING
  APPROVED
  SUSPENDED
}

model AgentTourPreference {
  id        String @id @default(cuid())
  agentId   String
  packageId String

  agent   Agent   @relation(fields: [agentId], references: [id])
  package Package @relation(fields: [packageId], references: [id])

  @@unique([agentId, packageId])
}

model BookingAgent {
  id          String           @id @default(cuid())
  bookingId   String           @unique
  agentId     String
  commission  Float
  status      AssignmentStatus @default(ASSIGNED)
  rating      Int?
  feedback    String?
  assignedAt  DateTime         @default(now())
  completedAt DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])
  agent   Agent   @relation(fields: [agentId], references: [id])
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  moto      String
  linkedin  String
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
